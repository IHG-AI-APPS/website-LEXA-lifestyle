from fastapi import APIRouter, HTTPException, Depends
from motor.motor_asyncio import AsyncIOMotorDatabase
from typing import List, Optional
from datetime import datetime, timezone
from models.projects import ProjectBase, ProjectCreate, ProjectUpdate
import logging

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/projects", tags=["Projects"])

def get_db():
    """Dependency to get database - will be injected by main app"""
    pass

# Public routes
@router.get("", response_model=List[ProjectBase])
async def get_projects(
    featured: Optional[bool] = None,
    category: Optional[str] = None,
    limit: int = 100,
    db: AsyncIOMotorDatabase = Depends(get_db)
):
    """Get all published projects"""
    query = {"published": True}
    
    if featured is not None:
        query["featured"] = featured
    
    if category:
        query["category"] = category
    
    projects = await db.projects.find(query, {"_id": 0}).sort("year", -1).limit(limit).to_list(limit)
    return projects

@router.get("/{project_id}", response_model=ProjectBase)
async def get_project_by_id(
    project_id: str,
    db: AsyncIOMotorDatabase = Depends(get_db)
):
    """Get a single project by ID or slug"""
    # Try to find by ID first, then by slug
    project = await db.projects.find_one(
        {"$or": [{"id": project_id}, {"slug": project_id}], "published": True},
        {"_id": 0}
    )
    
    if not project:
        raise HTTPException(status_code=404, detail="Project not found")
    
    return project

# Admin routes (these will need authentication middleware)
@router.post("/admin/create")
async def create_project(
    project: ProjectCreate,
    db: AsyncIOMotorDatabase = Depends(get_db)
):
    """Create a new project (admin only)"""
    import uuid
    
    project_dict = project.model_dump()
    project_dict["id"] = str(uuid.uuid4())
    project_dict["created_at"] = datetime.now(timezone.utc)
    project_dict["updated_at"] = datetime.now(timezone.utc)
    
    # Generate slug if not provided
    if not project_dict.get("slug"):
        from slugify import slugify
        project_dict["slug"] = slugify(project.title)
    
    await db.projects.insert_one(project_dict)
    
    return {"message": "Project created", "id": project_dict["id"]}

@router.put("/admin/{project_id}")
async def update_project(
    project_id: str,
    project: ProjectUpdate,
    db: AsyncIOMotorDatabase = Depends(get_db)
):
    """Update a project (admin only)"""
    update_data = {k: v for k, v in project.model_dump().items() if v is not None}
    update_data["updated_at"] = datetime.now(timezone.utc)
    
    result = await db.projects.update_one(
        {"id": project_id},
        {"$set": update_data}
    )
    
    if result.matched_count == 0:
        raise HTTPException(status_code=404, detail="Project not found")
    
    return {"message": "Project updated"}

@router.delete("/admin/{project_id}")
async def delete_project(
    project_id: str,
    db: AsyncIOMotorDatabase = Depends(get_db)
):
    """Delete a project (admin only)"""
    result = await db.projects.delete_one({"id": project_id})
    
    if result.deleted_count == 0:
        raise HTTPException(status_code=404, detail="Project not found")
    
    return {"message": "Project deleted"}
